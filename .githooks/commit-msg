#!/bin/sh
#
# Enforce Conventional Commits: https://www.conventionalcommits.org
#
# Format:  type(optional-scope)!: description
# Example: feat(books): add pagination to list endpoint
#
# Allowed types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert

commit_msg_file="$1"

# Read the first line (subject) of the commit message, ignoring comments.
subject=$(grep -v '^#' "$commit_msg_file" | sed '/^[[:space:]]*$/d' | head -n 1)

# Allow merge and revert commits that git generates automatically.
case "$subject" in
  "Merge "*|"Revert "*) exit 0 ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9_/-]+\))?!?: .+'

if printf '%s' "$subject" | grep -Eq "$pattern"; then
  exit 0
fi

echo "----------------------------------------------------------------------"
echo "  ✖ Commit message does not follow Conventional Commits."
echo ""
echo "  Got:      $subject"
echo ""
echo "  Required: <type>(<optional scope>): <description>"
echo "  Types:    feat, fix, docs, style, refactor, perf, test, build,"
echo "            ci, chore, revert"
echo ""
echo "  Examples:"
echo "    feat: add DELETE /books/:id endpoint"
echo "    fix(db): retry connection on startup"
echo "    docs: update README with docker steps"
echo "----------------------------------------------------------------------"
exit 1
